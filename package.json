{
  "name": "osa-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "kill:ports": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-osa-dev-ports.ps1",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }\"",
    "dev:clean": "npm run kill:ports && npm run clean && npm run dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "next": "14.2.35",
    "openai": "^6.36.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "undici": "^8.5.0"
  }
}
